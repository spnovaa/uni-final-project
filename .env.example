PLAN_CACHE_TTL=300
PROVIDER_CACHE_TTL=300
PROVIDER_MODEL_CACHE_TTL=300
PROVIDER_CONFIG_CACHE_TTL=300

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
