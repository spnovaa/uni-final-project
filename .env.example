DB_CONNECTION=sqlsrv
DB_HOST=DESKTOP-5LO22TN
DB_PORT=1434
DB_DATABASE=ai_gateway_dev
DB_USERNAME=sa
DB_PASSWORD=123456

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
